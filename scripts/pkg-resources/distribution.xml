<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>OdinMac</title>
    <organization>com.odinmac.app</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="true" hostArchitectures="arm64" rootVolumeOnly="true"/>

    <volume-check>
        <allowed-os-versions>
            <os-version min="13.0"/>
        </allowed-os-versions>
    </volume-check>

    <welcome file="welcome.html" mime-type="text/html"/>
    <license file="license.txt" mime-type="text/plain"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <pkg-ref id="com.odinmac.app.pkg"/>

    <choices-outline>
        <line choice="default">
            <line choice="com.odinmac.app.pkg"/>
        </line>
    </choices-outline>

    <choice id="default"/>
    <choice id="com.odinmac.app.pkg" visible="false">
        <pkg-ref id="com.odinmac.app.pkg"/>
    </choice>

    <pkg-ref id="com.odinmac.app.pkg" version="$(VERSION)" onConclusion="none">OdinMac.pkg</pkg-ref>
</installer-gui-script>
